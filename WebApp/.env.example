# Copy to .env.sit / .env.uat / .env.production or set in Vercel per environment
# SIT = devs (local), UAT = testers (deployed), PROD = production (deployed)

# Backend API base URL (no trailing slash). Must match the environment:
# - SIT: local backend (npm run dev in BackEnd)
# - UAT: Railway UAT backend URL
# - PROD: Railway PROD backend URL
VITE_API_URL=http://localhost:8080/api

# Environment label: sit | uat | production
VITE_APP_ENV=sit
